# ──────────────────────────────────────────────────────────────────────────────
# SwipeTake — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.
# ──────────────────────────────────────────────────────────────────────────────

# AI Content Generation (optional)
# Without this key the app works fine using the 110 built-in questions.
# WARNING: This key is bundled into client-side JS.
# For public deployments, proxy API calls through a backend instead.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Google AdSense (web)
# Sign up at https://adsense.google.com → Sites → Add site
# Create ad units at: AdSense → Ads → By ad unit
# ──────────────────────────────────────────────────────────────────────────────
VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_INTERSTITIAL_SLOT=1234567890
VITE_ADSENSE_BANNER_SLOT=0987654321

# ──────────────────────────────────────────────────────────────────────────────
# Google AdMob (native iOS & Android)
# Sign up at https://admob.google.com → Apps → Add app
# Create ad units at: AdMob → Apps → [Your App] → Ad units
# ──────────────────────────────────────────────────────────────────────────────
VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
VITE_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~ZZZZZZZZZZ
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/AAAAAAAAAA
VITE_ADMOB_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/BBBBBBBBBB
VITE_ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/CCCCCCCCCC

# ──────────────────────────────────────────────────────────────────────────────
# Vote tally backend (Railway)
# Railway provides DATABASE_URL automatically when you attach a Postgres plugin.
# Leave VITE_API_URL empty for same-origin deployment on Railway.
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:port/dbname
VITE_API_URL=
